#!/usr/bin/env bash
set -euo pipefail

SRC="/usr/share/refind/themes/neon"

if [ ! -d "$SRC" ]; then
    echo "Jones rEFInd theme puuttuu: $SRC"
    exit 1
fi

REFIND_DIR=""

for d in \
    /boot/efi/EFI/refind \
    /boot/EFI/refind \
    /efi/EFI/refind \
    /boot/refind
do
    if [ -d "$d" ] && [ -f "$d/refind.conf" ]; then
        REFIND_DIR="$d"
        break
    fi
done

if [ -z "$REFIND_DIR" ]; then
    echo "rEFInd-asennusta ei löytynyt automaattisesti."
    echo "Etsityt polut:"
    echo "  /boot/efi/EFI/refind"
    echo "  /boot/EFI/refind"
    echo "  /efi/EFI/refind"
    echo "  /boot/refind"
    exit 1
fi

mkdir -p "$REFIND_DIR/themes"
rm -rf "$REFIND_DIR/themes/neon"
cp -a "$SRC" "$REFIND_DIR/themes/neon"

if ! grep -qxF "include themes/neon/theme.conf" "$REFIND_DIR/refind.conf"; then
    printf '\ninclude themes/neon/theme.conf\n' >> "$REFIND_DIR/refind.conf"
fi

echo "Jones rEFInd neon -teema asennettu: $REFIND_DIR/themes/neon"
