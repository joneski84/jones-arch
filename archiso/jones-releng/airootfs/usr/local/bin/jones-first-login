#!/usr/bin/env bash
set -euo pipefail

mkdir -p "$HOME/.config/jones"

if [ -f "$HOME/.config/jones/first-login-done" ]; then
    exit 0
fi

touch "$HOME/.config/jones/first-login-done"

sleep 4

if command -v lookandfeeltool >/dev/null 2>&1; then
    lookandfeeltool -a org.kde.breezedark.desktop >/dev/null 2>&1 || true
fi

if command -v plasma-apply-wallpaperimage >/dev/null 2>&1; then
    plasma-apply-wallpaperimage /usr/share/wallpapers/JonesArch/contents/images/jones-neon-city.jpg >/dev/null 2>&1 || true
fi

jones-welcome >/dev/null 2>&1 &

# Jones: ei näytetä vanhaa Plasma/Breeze splash -logoanimaatiota
if command -v kwriteconfig6 >/dev/null 2>&1; then
    kwriteconfig6 --file ksplashrc --group KSplash --key Theme None >/dev/null 2>&1 || true
elif command -v kwriteconfig5 >/dev/null 2>&1; then
    kwriteconfig5 --file ksplashrc --group KSplash --key Theme None >/dev/null 2>&1 || true
else
    mkdir -p "$HOME/.config"
    cat > "$HOME/.config/ksplashrc" <<'EOF_KSPLASH'
[KSplash]
Theme=None
EOF_KSPLASH
fi

