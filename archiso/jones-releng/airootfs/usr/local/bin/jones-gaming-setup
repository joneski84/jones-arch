#!/usr/bin/env bash
set -euo pipefail

msg='Jones Gaming Setup

Nobara-tyylinen Proton-valinta tehdään GE-Protonilla.

Seuraavaksi avataan ProtonUp-Qt.
Valitse siellä:
  1. Add version
  2. Compatibility tool: GE-Proton
  3. Asenna uusin GE-Proton
  4. Käynnistä Steam uudelleen
  5. Steam -> Settings -> Compatibility
  6. Enable Steam Play for all titles
  7. Valitse GE-Proton oletukseksi

Steam tukee paikallisia Proton-versioita compatibilitytools.d-kansiossa. ProtonUp-Qt hoitaa tämän puolestasi.'

if command -v kdialog >/dev/null 2>&1; then
    kdialog --title "Jones Gaming Setup" --msgbox "$msg" || true
fi

if command -v protonup-qt >/dev/null 2>&1; then
    protonup-qt >/dev/null 2>&1 &
elif command -v pupgui2 >/dev/null 2>&1; then
    pupgui2 >/dev/null 2>&1 &
elif command -v python3 >/dev/null 2>&1; then
    python3 -m pupgui2 >/dev/null 2>&1 &
else
    if command -v kdialog >/dev/null 2>&1; then
        kdialog --title "ProtonUp-Qt puuttuu" --error "ProtonUp-Qt ei löytynyt. Tarkista että protonup-qt-bin asentui [jones]-reposta."
    else
        echo "ProtonUp-Qt ei löytynyt."
    fi
fi
