[Unit]
Description=Jones Arch Plymouth boot sound
DefaultDependencies=no
After=local-fs.target systemd-udev-settle.service plymouth-start.service
Before=display-manager.service sddm.service
Wants=systemd-udev-settle.service
ConditionPathExists=/usr/share/sounds/jones/jones-boot.wav

[Service]
Type=oneshot
ExecStart=/usr/local/bin/jones-boot-sound 1.0
TimeoutStartSec=12
RemainAfterExit=no

[Install]
WantedBy=multi-user.target
